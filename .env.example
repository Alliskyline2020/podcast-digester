# ============================================
# Podcast Digester 环境变量配置
# ============================================

# ------------------ LLM 配置 ------------------
# DeepSeek API Key (必填)
DEEPSEEK_API_KEY=sk-your-api-key-here

# DeepSeek API 端点（可选）
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# DeepSeek 模型名称（可选）
DEEPSEEK_MODEL=deepseek-chat

# ------------------ ASR 配置 ------------------
# Whisper 模型大小: tiny / small / medium / large
PODCAST_DIGESTER_WHISPER_MODEL=small

# Whisper 量化精度: int8 (CPU) / float16 (GPU)
PODCAST_DIGESTER_WHISPER_COMPUTE=int8

# Whisper 设备: cpu / cuda
PODCAST_DIGESTER_WHISPER_DEVICE=cpu

# ------------------ 数据目录 ------------------
# 数据目录（可选，默认为 ../data）
PODCAST_DIGESTER_DATA_DIR=../data

# ------------------ 成本控制 ------------------
# 单集最大 LLM 成本（美元）
PODCAST_DIGESTER_MAX_COST_PER_EPISODE=1.0

# ------------------ 其他 ------------------
# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ------------------ 安全配置 ------------------
# 共享密钥：配置后保护所有写操作（POST/PUT/DELETE/PATCH）。
# 留空时（开发模式）所有写操作放行，假定只 loopback 暴露。
# 公网部署必须设置；客户端（前端）通过 X-Admin-Token 头传入相同值。
# 生成建议：openssl rand -hex 32
PODCAST_DIGESTER_ADMIN_TOKEN=

# CORS 允许的来源（逗号分隔）。默认仅允许本地开发服务器。
# 示例：https://podcast.example.com,http://localhost:5173
PODCAST_DIGESTER_CORS_ORIGINS=
