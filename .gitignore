# ============================================
# Podcast Digester .gitignore
# ============================================

# ---------- Secrets & env (NEVER commit) ----------
.env
.env.local
.env.*.local
backend/.env
**/.env
!.env.example

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual envs
venv/
.venv/
env/
ENV/
backend/venv/
backend/.venv/

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
backend/htmlcov/
backend/.pytest_cache/

# ---------- Node / Frontend ----------
node_modules/
frontend/node_modules/
dist/
frontend/dist/
.vite/
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------- IDE / Editor ----------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# ---------- Project runtime artifacts ----------
# 数据目录下的运行时数据（媒体、导出、DB、cookies），保留目录结构但不跟踪内容
data/media/
data/exports/
data/cookies/
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm
# backend/app.db 是 cwd=backend 时的运行时 SQLite（含 WAL/journal 边车）
backend/app.db
backend/app.db-journal
backend/app.db-wal
backend/app.db-shm
# 备份与一次性快照（DB/媒体副本/迁移产物，非应用数据）
data/media.backup-*/
data/*_backup/
data/*.db.bak*
data/*.db.backup-*
data/*snapshot*.json
data/*dryrun*.json
# backend/data/ 是 cwd=backend 时误生成的副本目录，应用实际用 ../data
backend/data/

# PID 文件
.backend_pid
.frontend_pid
*.pid

# 测试 fixtures 中可能生成的大文件
*.mp3
*.m4a
*.wav
*.mp4
*.vtt

# Apple AFM ASR 缓存
backend/app/speech_analyzer_bridge/.build/
backend/app/speech_analyzer_bridge/.swiftpm/

# Plans / 临时输出（保留 docs/）
*.tmp
*.bak

# Sensitive credentials (session cookies, API tokens, etc.)
# 历史问题：cookies.txt 早期被误 commit，含 YouTube session cookies
backend/cookies.txt
*.cookies
cookies.txt

# 一次性运维 / 修复脚本（episode 专属，非生产代码，留磁盘但不入库）
backend/reprocess_*.py
backend/rerun_*.py
backend/repair_*.py
backend/fill_punct_fallback.py
backend/import_orphan_episodes.py
# 进度监控 / 批量生成 / 一次性测试脚本（过程件，非生产代码）
backend/*monitor*.py
backend/generate_*.py
backend/add_*.py
backend/run_tests*.py
backend/run_tests*.sh
backend/test_fixes.sh
backend/verify_fixes.sh
backend/add_glossary_example.sh
# 根目录 & backend 下的过程报告 / 阶段总结（README、LICENSE 除外；docs/ 保留）
/*_SUMMARY.md
/*_REPORT.md
/*_COMPLETE.md
/fix-report.md
/FIX*.md
/START*.md
/QUICK_START.md
/DEPLOYMENT_*.md
backend/*_SUMMARY.md
backend/*_REPORT.md
backend/README_FIXES.md
backend/AFM3_INTEGRATION.md
backend/TASK_STATUS.md
backend/YOUTUBE_*.md
