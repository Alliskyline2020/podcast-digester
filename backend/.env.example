# ============================================================================
# Podcast Digester — 环境变量示例
# 复制为 .env 并填入真实值：cp .env.example .env
# ============================================================================

# ---- 运行环境 ----
ENV=development
# 绑定地址 / 端口（前端默认通过 Vite 代理到 :8000）
PODCAST_DIGESTER_HOST=127.0.0.1
PODCAST_DIGESTER_PORT=8000
PODCAST_DIGESTER_LOG_LEVEL=INFO

# ---- LLM（必填）----
# 支持多 provider，仅 2 种协议：openai_compatible / anthropic_compatible
# provider 预设见 app/llm/config.py:PROVIDERS（deepseek/openai/anthropic/glm/qwen/doubao/moonshot）
# 正式变量用 LLM_*；DEEPSEEK_* 为向后兼容别名（二选一即可，LLM_* 优先）

# provider 预设名（决定默认 base_url / model / 协议推断）
LLM_PROVIDER=deepseek
# 显式覆盖协议（留空则按 LLM_PROVIDER 推断）：openai_compatible | anthropic_compatible
# LLM_PROVIDER_TYPE=

# API Key（必填）
LLM_API_KEY=
# 端点；留空则用 provider 预设或 SDK 官方默认
# LLM_BASE_URL=https://api.deepseek.com
# 模型名
LLM_MODEL=deepseek-chat

# ---- DEEPSEEK_* 旧变量（向后兼容别名，可继续用；与 LLM_* 同时存在时 LLM_* 优先）----
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# ---- 管理接口（可选）----
# 设置后，管理类接口需要带此 token；留空则不鉴权（仅本地单用户场景）
PODCAST_DIGESTER_ADMIN_TOKEN=

# ---- 成本 / 容量保护 ----
# 单集 LLM 花费上限（美元），超过则中止
PODCAST_DIGESTER_MAX_LLM_COST=5.0
# 单集时长上限（小时）
PODCAST_DIGESTER_MAX_EPISODE_HOURS=5.0

# ---- 网络（中国大陆访问 YouTube 等需要）----
# launchd 托管的服务不会自动继承 shell 代理；如需走代理在此配置或写入 plist
# HTTPS_PROXY=http://127.0.0.1:7897
# HTTP_PROXY=http://127.0.0.1:7897

# ---- ASR（可选调优；默认即可）----
# 无平台字幕时回退到 Apple AFM 3 语音识别，下列为轮询/超时相关参数
PODCAST_DIGESTER_ASR_MAX_WAIT=300
