# ============================================================================
# Podcast Digester — 环境变量示例
# 复制为 .env 并填入真实值：cp .env.example .env
# ============================================================================

# ---- 运行环境 ----
ENV=development
# 绑定地址 / 端口（前端默认通过 Vite 代理到 :8000）
PODCAST_DIGESTER_HOST=127.0.0.1
PODCAST_DIGESTER_PORT=8000
PODCAST_DIGESTER_LOG_LEVEL=INFO

# ---- LLM（必填）----
# DeepSeek API Key，处理流程的核心依赖（分章/摘要/翻译/亮点/洞察都走它）
DEEPSEEK_API_KEY=
# 官方端点；如走代理或自建网关可改
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 简单任务用非思考模型；亮点/洞察由代码内部切换思考模型
DEEPSEEK_MODEL=deepseek-chat

# ---- 管理接口（可选）----
# 设置后，管理类接口需要带此 token；留空则不鉴权（仅本地单用户场景）
PODCAST_DIGESTER_ADMIN_TOKEN=

# ---- 成本 / 容量保护 ----
# 单集 LLM 花费上限（美元），超过则中止
PODCAST_DIGESTER_MAX_LLM_COST=5.0
# 单集时长上限（小时）
PODCAST_DIGESTER_MAX_EPISODE_HOURS=5.0

# ---- 网络（中国大陆访问 YouTube 等需要）----
# launchd 托管的服务不会自动继承 shell 代理；如需走代理在此配置或写入 plist
# HTTPS_PROXY=http://127.0.0.1:7897
# HTTP_PROXY=http://127.0.0.1:7897

# ---- ASR（可选调优；默认即可）----
# 无平台字幕时回退到 Apple AFM 3 语音识别，下列为轮询/超时相关参数
PODCAST_DIGESTER_ASR_MAX_WAIT=300
